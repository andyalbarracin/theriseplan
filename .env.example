# Supabase (optional — the app runs fully on mock data without these).
# When set, the CMS data layer can be switched to Supabase behind the same interface.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Data source: "mock" (default) | "supabase"
NEXT_PUBLIC_DATA_SOURCE=mock

# Public site URL (used for canonical/OG/sitemap).
NEXT_PUBLIC_SITE_URL=https://andyalbarracin.com
